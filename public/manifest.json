{
  "manifest_version": 3,
  "name": "Council",
  "description": "Coordinate the AI websites you already use as a private expert council.",
  "version": "0.1.1",
  "minimum_chrome_version": "116",
  "permissions": ["tabs", "storage", "scripting", "sidePanel", "tabGroups"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*"
  ],
  "background": { "service_worker": "assets/serviceWorker.js", "type": "module" },
  "action": { "default_title": "Open Council" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [{
    "matches": ["https://chatgpt.com/*", "https://claude.ai/*", "https://gemini.google.com/*", "https://grok.com/*", "https://kimi.com/*", "https://www.kimi.com/*"],
    "js": ["assets/contentScript.js"],
    "run_at": "document_idle"
  }]
}
